# ============================================================
# .env.local — único arquivo na raiz do monorepo, lido por web e api
# Setup: `cp .env.example .env.local` e depois `npm run env:link`
# (`env:link` cria symlinks em apps/web/.env.local e apps/api/.env
# apontando para este arquivo na raiz)
# ============================================================

# --- Auth (web e api compartilham NEXTAUTH_SECRET) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                  # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Web ---
API_URL=http://localhost:3001

# --- API ---
ALLOWED_ORIGINS=http://localhost:3000
PORT=3001
NODE_ENV=development
ADMIN_EMAILS=lsc@kainos-labs.com.br

# --- S2S (web → api) ---
# openssl rand -base64 48
# Railway: setar no api, web usa service reference ${{api.INTERNAL_SERVICE_TOKEN}}
INTERNAL_SERVICE_TOKEN=

# --- DB (api only) ---
DATABASE_URL=postgresql://invoices:invoices@localhost:5432/invoices

# ============================================================
# F2 — OCR / Storage (api only)
# ------------------------------------------------------------
# Em DEV local: OCR_PROVIDER=mock + OPENAI_API_KEY vazia.
# Em PROD (Railway): OCR_PROVIDER=openai + OPENAI_API_KEY setada.
# Spec: docs/superpowers/specs/2026-05-07-fase-2-ocr.md §8.7.
# ============================================================
OPENAI_API_KEY=
OCR_PROVIDER=mock                 # openai | mock — prod usa "openai"
OCR_MODEL=gpt-4o
UPLOAD_MAX_BYTES=10485760
STORAGE_URL_SECRET=               # openssl rand -base64 32

# Storage driver: volume (dev/test, Railway Volume) | r2 (prod, Cloudflare R2)
STORAGE_DRIVER=volume
VOLUME_ROOT=./.data/volume        # usado quando STORAGE_DRIVER=volume

# Cloudflare R2 — obrigatório apenas quando STORAGE_DRIVER=r2
# Criar bucket em dash.cloudflare.com → R2 → Create bucket
# API token: R2:Object Read+Write permission
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ============================================================
# F2.5 — Benchmark admin (api only)
# ------------------------------------------------------------
# Caminho absoluto para o dataset rotulado lido por
# /api/v1/admin/benchmark. Em DEV deixar vazio: a app resolve
# automaticamente para `../../samples/invoice-dataset` a partir
# do cwd da api. Em Docker o ENV já vem setado no Dockerfile
# como /app/samples/invoice-dataset.
# ============================================================
BENCHMARK_DATASET_DIR=

# ============================================================
# F3 — Chat / LLM (api only)
# ------------------------------------------------------------
# Em DEV local: LLM_PROVIDER=mock (sem consumo de tokens).
# Em PROD (Railway): LLM_PROVIDER=openai + OPENAI_API_KEY setada.
# ============================================================
CHAT_MODEL=gpt-4o-mini
CHAT_STREAMING=false
CHAT_MAX_HISTORY=20
CHAT_MAX_TOOL_ITERATIONS=3
LLM_PROVIDER=mock             # openai | mock (use mock em dev local)
