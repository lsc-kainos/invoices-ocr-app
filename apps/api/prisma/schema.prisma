// Schema Prisma — invoices-ocr-app
// Aprenda mais: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum DocumentStatus {
  QUEUED
  OCR_RUNNING
  READY
  FAILED
  REJECTED
  DUPLICATE
}

enum ChatRole {
  USER
  ASSISTANT
  TOOL
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents         Document[]
  chatSessions      ChatSession[]
  llmConfigs        LlmConfig[]
  verifiedDocuments Document[]     @relation("DocumentVerifier")
  documentEdits     DocumentEdit[]
  benchmarkRuns     BenchmarkRun[]
}

model Document {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  filename    String
  mime        String
  size        Int
  storagePath String

  status          DocumentStatus @default(QUEUED)
  failureReason   String?
  retryCount      Int            @default(0)
  semanticHash    String?
  duplicateOfId   String?
  duplicateOf     Document?      @relation("DocumentDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates      Document[]     @relation("DocumentDuplicates")
  duplicateReason String?

  summary       Json?
  extractedText String? @db.Text

  ocrStartedAt   DateTime?
  ocrCompletedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  documentType    String?
  confidence      Float?
  rejectionReason String?
  verifiedAt      DateTime?
  verifiedBy      String?
  verifier        User?          @relation("DocumentVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)
  edits           DocumentEdit[]

  chatSessions ChatSession[]

  @@index([userId, status])
  @@index([userId, semanticHash, status])
  @@index([duplicateOfId])
  @@index([userId, updatedAt])
}

model ChatSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  title    String?
  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, documentId])
  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role    ChatRole
  content String   @db.Text

  toolCallId String?
  toolName   String?
  toolArgs   Json?

  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

enum LlmConfigKey {
  EXTRACTOR
  CHAT
}

model LlmConfig {
  id        String       @id @default(cuid())
  key       LlmConfigKey
  version   Int
  model     String
  prompt    String       @db.Text
  params    Json
  active    Boolean      @default(false)
  notes     String?      @db.Text
  createdBy String
  creator   User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  benchmarkRuns BenchmarkRun[]

  @@unique([key, version])
  @@index([key, active])
}

model BenchmarkRun {
  id             String     @id @default(cuid())
  runBy          String
  runner         User       @relation(fields: [runBy], references: [id], onDelete: Cascade)
  llmConfigId    String?
  llmConfig      LlmConfig? @relation(fields: [llmConfigId], references: [id], onDelete: SetNull)
  modelSnapshot  String
  promptSnapshot String     @db.Text
  paramsSnapshot Json
  datasetVersion String
  sampleCount    Int
  aggregate      Json
  results        Json
  durationMs     Int
  createdAt      DateTime   @default(now())

  @@index([createdAt])
  @@index([llmConfigId, createdAt])
}

model DocumentEdit {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  editedBy   String
  editor     User     @relation(fields: [editedBy], references: [id], onDelete: Cascade)
  before     Json
  after      Json
  createdAt  DateTime @default(now())

  @@index([documentId, createdAt])
}
